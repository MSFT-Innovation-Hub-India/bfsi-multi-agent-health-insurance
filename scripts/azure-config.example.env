# ============================================================
# Azure Resource Names for Networking Script
# Copy this to .env or set as environment variables
# ============================================================

# Required: Azure Resource Group
AZURE_RESOURCE_GROUP=your-resource-group-name

# Required: Azure Subscription ID
AZURE_SUBSCRIPTION_ID=your-subscription-id

# Blob Storage Account Name (without .blob.core.windows.net)
AZURE_STORAGE_ACCOUNT_NAME=yourstorageaccount

# Cosmos DB Account Name (without .documents.azure.com)
COSMOS_DB_ACCOUNT_NAME=yourcosmosaccount
